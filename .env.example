# Kendi Supabase projenizi oluşturduktan sonra bu değerleri doldurun.
# Project Settings → API bölümünden alın.
# Sonra bu dosyayı .env olarak kopyalayın veya .env içine yapıştırın.

VITE_SUPABASE_URL="https://BURAYA_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="BURAYA_ANON_PUBLIC_KEY"
VITE_SUPABASE_PROJECT_ID="BURAYA_PROJECT_REF"

# Opsiyonel: Özel domain kullanıyorsanız production'da (e-posta linkleri, canonical URL için).
# Aksi halde uygulama window.location.origin kullanır.
# VITE_SITE_URL="https://newcatalog.com"
