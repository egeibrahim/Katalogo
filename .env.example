# ============================================================
# Değişken karşısına ne yazacaksınız? (Value nereden alınır?)
# ============================================================
# Supabase: supabase.com/dashboard → Projeniz → Project Settings (dişli) → API
#
# VITE_SUPABASE_URL          → API sayfasındaki "Project URL" (örn. https://abcdefgh.supabase.co)
# VITE_SUPABASE_PUBLISHABLE_KEY → API sayfası "Project API keys" → anon / public satırındaki uzun key
# VITE_SUPABASE_PROJECT_ID   → API sayfasındaki "Reference ID" (örn. abcdefgh) — opsiyonel
#
# VITE_SITE_URL              → Özel domain: https://katalogo.co — opsiyonel
# Arka plan kaldırma (tasarımcı): iLoveIMG API
# VITE_ILOVEIMG_PUBLIC_KEY   → developer.iloveimg.com → projeniz → API Keys → Public key
# ============================================================
# Yerel: bu dosyayı .env olarak kopyalayıp Value'ları doldurun.
# Vercel: Settings → Environment Variables → Key + Value aynı isimlerle ekleyin (docs/VERCEL_DEPLOY.md §2.1)
# ============================================================

VITE_SUPABASE_URL="https://fyjztlhtxubeedyqublo.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_FrH6hp2KDmN56_8KYLZqug_Xly2-01u"
VITE_SUPABASE_PROJECT_ID="fyjztlhtxubeedyqublo"

